---
import DashboardIsland from "../components/DashboardIsland";
export const prerender = false;
---

<html>
  <body>
    <DashboardIsland client:load />

    <style>
      body {
        font-family: system-ui;
        background: #f5f5f5;
        padding: 40px;
      }
      section {
        margin: 40px auto;
        max-width: 1200px;
        padding: 0 20px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 8px;
        border-bottom: 1px solid #333;
      }

      button {
        padding: 4px 8px;
        margin-right: 4px;
      }
    </style>
  </body>
</html>
